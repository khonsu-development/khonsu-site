---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
---

<BaseLayout title="About — Khonsu Development" canonicalPath="/about">
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-3xl">
        <h1 class="text-3xl font-black tracking-tight sm:text-5xl">About</h1>
        <p class="mt-4 text-zinc-300">
          Khonsu Development builds focused learning apps: thoughtfully
          structured, visually clean, and designed to make niche subjects feel
          approachable.
        </p>

        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          <div class="card p-6">
            <div class="text-sm font-semibold text-white">
              A “World of Apps”
            </div>
            <p class="mt-3 text-sm leading-relaxed text-zinc-300">
              We’re building one app per letter — each a deep dive into a
              specific topic. It’s a playful constraint that keeps the catalog
              eclectic and the quality bar high.
            </p>
          </div>
          <div class="card p-6">
            <div class="text-sm font-semibold text-white">
              Confidence through clarity
            </div>
            <p class="mt-3 text-sm leading-relaxed text-zinc-300">
              Every app aims for structure, accuracy, and a calm reading
              experience — so you can trust what you’re learning and enjoy the
              journey.
            </p>
          </div>
        </div>

        <div class="card mt-10 p-6">
          <div class="text-sm font-semibold text-white">Collaboration</div>
          <p class="mt-3 text-sm leading-relaxed text-zinc-300">
            We also collaborate with friends at Lyricspiration, creators of
            Double Rhyme, on learning experiences around freestyle rap.
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
