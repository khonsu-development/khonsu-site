---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
---

<BaseLayout
  title="World of Communism — Khonsu Development"
  description="Explore Communism, Socialism, and Anarchism — thinkers, movements, writings, maps, music, and quizzes."
  canonicalPath="/communism"
>
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-3xl">
        <article
          class="prose prose-invert prose-headings:tracking-tight prose-p:text-zinc-200 prose-li:text-zinc-200 max-w-none"
        >
          <h1>Get ready for the Revolution, Comrade!</h1>
          <p>Your guide to revolutionary thinkers and their works.</p>
          <p>
            Learn all about Communism and Anarchism with World of Communism.
          </p>

          <blockquote>
            <p>“The first duty of a man is to think for himself”</p>
            <p>— Jose Marti, Cuban poet and philosopher</p>
          </blockquote>

          <h2>Features</h2>

          <h3>Treasure trove of information</h3>
          <p>
            Discover <strong>140+</strong> key Communist and Anarchist personalities,
            as well as dozens of movements and writings — neatly organised.
          </p>

          <h3>Meet the vanguard</h3>
          <p>
            Explore philosophers, artists, and politicians — from Karl Marx to
            Emma Goldman — through their ideas, struggles, and lasting impact.
          </p>

          <h3>Interactive map</h3>
          <p>
            Explore an interactive map to learn about each country's Communist
            and Anarchist experiences.
          </p>

          <h3>Music for a revolution</h3>
          <p>
            Discover left-wing hymns and songs — with lyrics — from all around
            the world.
          </p>

          <h3>Category quizzes</h3>
          <p>
            Test your knowledge with engaging quizzes across movements,
            influential figures, songs, and books — fun, challenging
            multiple-choice questions.
          </p>

          <h3>Tailored quizzes</h3>
          <p>
            Design quizzes based on what you want to study — great for learners
            at any level.
          </p>

          <h3>Navigate movements</h3>
          <p>
            Confused about the difference between Ethical Socialism and Green
            Anarchism? Detailed descriptions help you navigate left-wing
            movements.
          </p>

          <h3>Dark theme</h3>
          <p>
            Sleek elegance and eye comfort — built for long reading sessions.
          </p>

          <blockquote>
            <p>
              “Freedom is always and exclusively freedom for the one who thinks
              differently.”
            </p>
            <p>
              — Rosa Luxemburg, revolutionary socialist and anti-war activist
            </p>
          </blockquote>

          <p>
            If you found a bug or a content error, please report it to{" "}
            <a href="mailto:khonsu.development@gmail.com"
              >khonsu.development@gmail.com</a
            >.
          </p>
        </article>

        <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
          <a
            class="btn btn-primary"
            href="https://play.google.com/store/apps/details?id=eu.khonsu.communism"
            rel="noopener noreferrer"
            target="_blank"
          >
            Get it on Google Play
          </a>
          <a class="btn btn-secondary" href="/apps/world-of-communism">
            View on this site
          </a>
        </div>

        <div class="mt-10 text-sm text-zinc-400">
          <a
            class="underline decoration-white/20 underline-offset-4 hover:text-white"
            href="/communism/terms-and-conditions-for-world-of-communism"
          >
            Terms &amp; Conditions for World of Communism
          </a>
          {" · "}
          <a
            class="underline decoration-white/20 underline-offset-4 hover:text-white"
            href="/communism/privacy-policy-for-world-of-communism"
          >
            Privacy Policy for World of Communism
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
