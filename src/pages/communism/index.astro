---
import AppLandingAerium from "../../components/AppLandingAerium.astro";

const stats = [
  { label: "Key thinkers", value: "140+" },
  { label: "Study modes", value: "Browse + quiz" },
  { label: "Learning style", value: "Structured" },
];

const features = [
  {
    title: "Thinkers with context",
    body: "Explore philosophers, artists, and political figures, understand ideas, lives, and influence without the jargon fog.",
  },
  {
    title: "Movements & definitions",
    body: "From ethical socialism to green anarchism, navigate labels and distinctions with clean explanations.",
  },
  {
    title: "Writings & references",
    body: "A curated library of texts and themes, so reading recommendations feel actionable rather than overwhelming.",
  },
  {
    title: "Interactive map",
    body: "See how countries intersected with communist and anarchist histories through a browsable map view.",
  },
  {
    title: "Songs & hymns",
    body: "Discover left-wing music from around the world, with lyrics for exploration and cultural context.",
  },
  {
    title: "Quizzes that reinforce vocabulary",
    body: "Category quizzes and tailored sets help you turn reading into memory, great for beginners and enthusiasts.",
  },
  {
    title: "Built for calm reading",
    body: "A polished dark UI designed for long sessions and focused study.",
  },
  {
    title: "Learn end‑to‑end",
    body: "Ideas → people → movements → places → culture. The app is designed as a cohesive learning journey.",
  },
];
---
<AppLandingAerium
  canonicalPath="/communism"
  title="World of Communism | Khonsu Development"
  description="Explore Communism, Socialism, and Anarchism through thinkers, movements, maps, music, and quizzes."
  themeColor="app-communism"
  appName="World of Communism"
  logoSrc="/apps/communism/communism.png"
  eyebrow="Ideas, history, and movements, made navigable"
  headline="Understand the left, clearly"
  subhead="A structured guide to communist, socialist, and anarchist ideas: key thinkers, movements, writings, maps, songs, and quizzes."
  googlePlayUrl="https://play.google.com/store/apps/details?id=eu.khonsu.communism"
  screenshots={["/apps/communism/framed-1.png", "/apps/communism/framed-2.png"]}
  coverImage="/stock/apps/communism/cover.jpg"
  coverImageAlt="A crowd holding flags during a May Day demonstration."
  stats={stats}
  features={features}
  faqs={[
    {
      q: "Is this propaganda?",
      a: "No. It’s a structured learning tool that helps you understand ideas, people, and movements with context, so you can think for yourself.",
    },
    {
      q: "Do I need prior knowledge?",
      a: "Not at all. Start with quick browsing and definitions, then deepen with writings, maps, and quizzes as you go.",
    },
    {
      q: "What’s the best way to use it?",
      a: "Pick one thread (an idea, a person, or a movement), follow the links, then reinforce with a tailored quiz.",
    },
  ]}
  termsUrl="/communism/terms-and-conditions-for-world-of-communism"
  privacyUrl="/communism/privacy-policy-for-world-of-communism"
/>
