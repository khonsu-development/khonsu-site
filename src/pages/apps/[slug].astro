---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";

export async function getStaticPaths() {
  const apps = await getCollection("apps");
  return apps.map((app) => ({
    params: { slug: app.id.replace(/\.(md|mdx)$/, "") },
    props: { app },
  }));
}

const { app } = Astro.props;
const slug = app.id.replace(/\.(md|mdx)$/, "");
const { Content } = await render(app);

if (
  app.data.websiteUrl &&
  app.data.websiteUrl.startsWith("/") &&
  !app.data.websiteUrl.startsWith("/apps/")
) {
  return Astro.redirect(app.data.websiteUrl, 301);
}

const themeColor = app.data.themeColor;
const themeStyle = themeColor
  ? `--app-primary: var(--color-${themeColor}-primary); --app-secondary: var(--color-${themeColor}-secondary);`
  : `--app-primary: var(--color-brand); --app-secondary: var(--color-brand2);`;

const pageTitle = app.data.seoTitle ?? `${app.data.name} | Khonsu Development`;
const pageDescription = app.data.seoDescription ?? app.data.tagline;
const ogImage = app.data.ogImage ?? app.data.coverImage;

const schemaOrg = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: app.data.name,
  description: pageDescription,
  applicationCategory: "EducationalApplication",
  operatingSystem: (app.data.platforms ?? [])
    .map((p) => (p === "android" ? "Android" : p === "ios" ? "iOS" : "Web"))
    .join(", "),
  image: ogImage
    ? ogImage.startsWith("http")
      ? ogImage
      : `https://www.khonsu.eu${ogImage}`
    : undefined,
  url: `https://www.khonsu.eu/apps/${slug}`,
  downloadUrl: app.data.googlePlayUrl ?? app.data.appStoreUrl,
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/apps/${slug}`}
  ogImage={ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-3xl" data-app-theme={app.data.themeColor}>
        <a
          class="text-sm font-semibold text-zinc-300 hover:text-white"
          href="/apps">← All apps</a
        >

        <div class="card mt-6 overflow-hidden" style={themeStyle}>
          <div class="relative">
            {
              app.data.coverImage ? (
                <div class="relative aspect-[16/8] overflow-hidden">
                  <img
                    src={app.data.coverImage}
                    alt={
                      app.data.coverImageAlt ?? `${app.data.name} cover image`
                    }
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/50 to-transparent"
                  />
                </div>
              ) : (
                <div
                  aria-hidden="true"
                  class="aspect-[16/8]"
                  style={`background: radial-gradient(900px circle at 30% 25%, color-mix(in oklab, var(--app-primary) 38%, transparent), transparent 55%), linear-gradient(135deg, color-mix(in oklab, var(--app-primary) 22%, black), color-mix(in oklab, var(--app-secondary) 16%, black));`}
                />
              )
            }

            <div class="relative -mt-10 p-6 sm:p-8">
              <div class="flex items-start gap-4">
                <div
                  class="h-14 w-14 shrink-0 overflow-hidden rounded-2xl ring-1 ring-white/10"
                  style={`background: color-mix(in oklab, var(--app-primary) 55%, black);`}
                >
                  {
                    app.data.icon ? (
                      <img
                        src={app.data.icon}
                        alt={`${app.data.name} app icon`}
                        class="h-full w-full object-cover"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="h-full w-full bg-white/5" />
                    )
                  }
                </div>
                <div class="min-w-0">
                  <h1
                    class="text-3xl font-black tracking-tight text-balance text-white sm:text-5xl"
                  >
                    {app.data.name}
                  </h1>
                  <p class="mt-3 text-lg text-pretty text-zinc-200">
                    {app.data.tagline}
                  </p>

                  {
                    (app.data.topics?.length || app.data.platforms?.length) && (
                      <div class="mt-5 flex flex-wrap gap-2">
                        {(app.data.topics ?? []).slice(0, 4).map((t) => (
                          <span class="rounded-full bg-white/5 px-3 py-1.5 text-xs font-medium text-white ring-1 ring-white/10">
                            {t}
                          </span>
                        ))}
                        {(app.data.platforms ?? []).map((p) => (
                          <span
                            class="rounded-full px-3 py-1.5 text-xs font-semibold ring-1 ring-white/10"
                            style={`background: color-mix(in oklab, var(--app-primary) 18%, black); color: white;`}
                          >
                            {p}
                          </span>
                        ))}
                      </div>
                    )
                  }
                </div>
              </div>

              <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
                {
                  app.data.googlePlayUrl ? (
                    <a
                      class="inline-flex focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/60"
                      href={app.data.googlePlayUrl}
                      rel="noopener noreferrer"
                      target="_blank"
                      aria-label="Get it on Google Play"
                    >
                      <img
                        src="/google-play-badges/GetItOnGooglePlay_Badge_Web_color_English.svg"
                        alt="Get it on Google Play"
                        class="h-14 w-auto sm:h-16"
                        decoding="async"
                      />
                    </a>
                  ) : null
                }
                {
                  app.data.appStoreUrl ? (
                    <a
                      class="btn btn-secondary"
                      href={app.data.appStoreUrl}
                      rel="noopener noreferrer"
                      target="_blank"
                    >
                      Download on the App Store
                    </a>
                  ) : null
                }
              </div>

              {
                app.data.privacyUrl ||
                app.data.termsUrl ||
                app.data.websiteUrl ? (
                  <div class="mt-6 flex flex-col gap-2 text-sm text-zinc-300 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-6 sm:gap-y-2">
                    {app.data.websiteUrl ? (
                      <a
                        class="font-semibold text-white hover:underline"
                        href={app.data.websiteUrl}
                      >
                        App microsite
                      </a>
                    ) : null}
                    {app.data.privacyUrl ? (
                      <a
                        class="font-semibold text-white hover:underline"
                        href={app.data.privacyUrl}
                      >
                        App privacy policy
                      </a>
                    ) : null}
                    {app.data.termsUrl ? (
                      <a
                        class="font-semibold text-white hover:underline"
                        href={app.data.termsUrl}
                      >
                        App terms &amp; conditions
                      </a>
                    ) : null}
                  </div>
                ) : null
              }
            </div>
          </div>
        </div>

        <article
          class="prose prose-invert prose-p:text-zinc-200 prose-li:text-zinc-200 mt-10 max-w-none"
        >
          <Content />
        </article>
      </div>
    </Container>
  </section>
</BaseLayout>
