---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/Container.astro";
import AppCard from "../../components/AppCard.astro";

const apps = await getCollection("apps");
const priority = [
  "world-of-alphabets",
  "world-of-dinosaurs",
  "world-of-communism",
  "freestyle-rap",
] as const;

const priorityRank = new Map(priority.map((slug, idx) => [slug, idx]));

function slugOf(app: (typeof apps)[number]) {
  return app.id.replace(/\.(md|mdx)$/, "");
}

const orderedApps = [...apps].sort((a, b) => {
  const ar = priorityRank.get(slugOf(a)) ?? Number.POSITIVE_INFINITY;
  const br = priorityRank.get(slugOf(b)) ?? Number.POSITIVE_INFINITY;
  if (ar !== br) return ar - br;
  return a.data.name.localeCompare(b.data.name, "en");
});
---

<BaseLayout
  title="Educational apps for deep dives | Khonsu Development"
  description="Discover Khonsu’s educational apps: bite-sized learning experiences that go deep into niche topics. Beautiful design, clear structure, and satisfying progress."
  canonicalPath="/apps"
>
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-2xl">
        <h1 class="text-3xl font-black tracking-tight sm:text-5xl">Apps</h1>
        <p class="mt-4 text-zinc-300">
          A small, growing catalog of learning apps, each one a carefully crafted
          “world” you can explore in minutes a day (or lose an entire evening
          to).
        </p>
      </div>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          orderedApps.map((app) => (
            <AppCard
              app={app}
              href={
                app.data.websiteUrl && app.data.websiteUrl.startsWith("/")
                  ? app.data.websiteUrl
                  : `/apps/${app.id.replace(/\.(md|mdx)$/, "")}`
              }
            />
          ))
        }
      </div>
    </Container>
  </section>
</BaseLayout>
