---

<AppLandingAerium
  canonicalPath="/alphabets"
  title="World of Alphabets | Khonsu Development"
  description="Learn writing systems with flashcards, quizzes, and a script map. Explore 267+ alphabets and 2400+ characters."
  themeColor="app-alphabets"
  appName="World of Alphabets"
  logoSrc="/apps/alphabets/alphabets.png"
  eyebrow="A writing systems atlas in your pocket"
  headline="Learn writing systems without the overwhelm"
  subhead="Explore 267+ writing systems and 2400+ characters with flashcards and quizzes—plus a world map of scripts."
  googlePlayUrl="https://play.google.com/store/apps/details?id=eu.khonsu.alphabets"
  screenshots={[
    "/apps/alphabets/features/alphabet-overview.png",
    "/apps/alphabets/features/script-map.png",
  ]}
  centerScreenshot="/apps/alphabets/features/main-menu.png"
  coverImage="/stock/alphabets/cover-hebrew.jpg"
  coverImageAlt="Close-up of an ancient text with Hebrew writing."
  stockImages={[
    {
      src: "/stock/alphabets/egyptian-hieroglyphic.jpg",
      alt: "",
    },
    {
      src: "/stock/alphabets/cuneiform.jpg",
      alt: "",
    },
    {
      src: "/stock/alphabets/arabic.jpg",
      alt: "",
    },
    {
      src: "/stock/alphabets/chinese.jpg",
      alt: "",
    },
    {
      src: "/stock/alphabets/runes.jpg",
      alt: "",
    },
  ]}
  heroSpotlightStats={heroSpotlightStats}
  stats={stats}
  features={features}
  featuresSectionTitle="Features"
  featuresSectionSubtitle="Explore writing systems, practice characters, browse languages on a map, and more."
  writingSystemsWithSigns={writingSystemsWithSigns}
  writingSystemsTitle="Writing systems with signs"
  writingSystemsSubtitle="These writing systems include character signs you can study inside the app."
  testimonials={testimonials}
  postCarouselBlurb={{
    title: "Humanity, written down",
    body: "Scripts carry laws, prayers, jokes, and grocery lists—the traces of real lives across continents. Wander through that diversity at your own pace: no homework, no pressure, just curiosity.",
    stockImages: [
      { src: "/stock/alphabets/greek.jpg", alt: "" },
      { src: "/stock/alphabets/coptic.jpg", alt: "" },
      { src: "/stock/alphabets/tibetan.jpg", alt: "" },
      { src: "/stock/alphabets/kanji.jpg", alt: "" },
      { src: "/stock/alphabets/korean.jpg", alt: "" },
    ],
  }}
  faqs={[
    {
      q: "Is this just flashcards?",
      a: "No. World of Alphabets is also an atlas and a reference. You can explore scripts by history, region, and language, then switch into practice mode when you’re ready.",
    },
    {
      q: "Can I learn fictional or constructed alphabets too?",
      a: "Yes. Alongside historical writing systems, you’ll find constructed scripts and pop-culture favorites to keep exploration fun.",
    },
    {
      q: "Is it good for short daily practice?",
      a: "Absolutely. The flow is designed for quick sessions. Browse a script, learn a few characters, take a quiz, and you’re done.",
    },
  ]}
  termsUrl="/alphabets/terms-and-conditions-for-world-of-alphabets"
  privacyUrl="/alphabets/privacy-policy-for-world-of-alphabets"
  youtubeVideoId="AJv_n7niDWo"
  youtubeVideoTitle="See World of Alphabets in action"
