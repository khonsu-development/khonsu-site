---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
---

<BaseLayout title="Contact — Khonsu Development" canonicalPath="/contact">
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-2xl">
        <h1 class="text-3xl font-black tracking-tight sm:text-5xl">Contact</h1>
        <p class="mt-4 text-zinc-300">
          Tell us what you’re curious about, suggest a topic, or reach out for collaboration.
        </p>

        <div class="mt-10 card p-6">
          <div class="text-sm font-semibold text-white">Email</div>
          <p class="mt-3 text-sm leading-relaxed text-zinc-300">
            Add your preferred email address here (we’ll keep it spam-resistant if you want).
          </p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row">
            <a class="btn btn-primary" href="mailto:hello@khonsu.eu">Email us</a>
            <a class="btn btn-secondary" href="/press">Press kit</a>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

