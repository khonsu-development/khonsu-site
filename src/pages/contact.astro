---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
---

<BaseLayout
  title="Contact | Khonsu Development"
  description="Contact Khonsu Development with feedback, topic suggestions, bug reports, or collaboration ideas."
  canonicalPath="/contact"
>
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-2xl">
        <h1 class="text-3xl font-black tracking-tight sm:text-5xl">Contact</h1>
        <p class="mt-4 text-zinc-300">
          Got feedback, a bug report, or a niche topic you’d love to explore?
          Send it over (collaborations welcome too).
        </p>

        <div class="card mt-10 p-6">
          <div class="text-sm font-semibold text-white">Email</div>
          <p class="mt-3 text-sm leading-relaxed text-zinc-300">
            Prefer email? Reach us at <span class="text-white"
              >khonsu.development@gmail.com</span
            >.
          </p>
          <div class="mt-4 flex flex-col gap-3 sm:flex-row">
            <a
              class="btn btn-primary"
              href="mailto:khonsu.development@gmail.com">Email us</a
            >
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
