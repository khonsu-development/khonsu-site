---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
---

<BaseLayout title="Press — Khonsu Development" canonicalPath="/press">
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-3xl">
        <h1 class="text-3xl font-black tracking-tight sm:text-5xl">
          Press / Media kit
        </h1>
        <p class="mt-4 text-zinc-300">
          Assets and facts for partners, reviewers, and press. (We’ll replace
          placeholders with your real logo pack and screenshots.)
        </p>

        <div class="mt-10 grid gap-5 sm:grid-cols-2">
          <div class="card p-6">
            <div class="text-sm font-semibold text-white">Boilerplate</div>
            <p class="mt-3 text-sm leading-relaxed text-zinc-300">
              Khonsu Development creates educational mobile apps that help
              curious minds explore niche topics through curated content and
              interactive learning.
            </p>
          </div>
          <div class="card p-6">
            <div class="text-sm font-semibold text-white">Contact</div>
            <p class="mt-3 text-sm leading-relaxed text-zinc-300">
              For press inquiries, reach out via the contact page.
            </p>
            <div class="mt-4">
              <a class="btn btn-secondary" href="/contact">Contact</a>
            </div>
          </div>
        </div>

        <div class="card mt-10 p-6">
          <div class="text-sm font-semibold text-white">Downloads</div>
          <p class="mt-3 text-sm leading-relaxed text-zinc-300">
            Add your logo pack, brand colors, and screenshots in <code
              >public/press</code
            >. We’ll surface them here as direct downloads.
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
