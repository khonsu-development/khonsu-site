---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
---

<BaseLayout title="Privacy — Khonsu Development" canonicalPath="/privacy">
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-3xl">
        <h1 class="text-3xl font-black tracking-tight sm:text-5xl">Privacy</h1>
        <div class="mt-8 card p-6">
          <p class="text-sm leading-relaxed text-zinc-300">
            This is a placeholder privacy page for the website. For each app, we’ll link the
            correct privacy policy from its app detail page.
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

