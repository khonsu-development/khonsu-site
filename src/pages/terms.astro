---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
---

<BaseLayout title="Terms — Khonsu Development" canonicalPath="/terms">
  <section class="py-12 sm:py-16">
    <Container>
      <div class="max-w-3xl">
        <h1 class="text-3xl font-black tracking-tight sm:text-5xl">Terms</h1>
        <div class="mt-8 card p-6">
          <p class="text-sm leading-relaxed text-zinc-300">
            This is a placeholder terms page for the website. We can replace it with your preferred
            terms text, or link out to app-specific terms where appropriate.
          </p>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

