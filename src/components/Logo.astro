---
type Props = { class?: string };
const { class: className } = Astro.props;
---

<span
  class:list={[
    "inline-flex items-center gap-2 font-semibold tracking-tight",
    className,
  ]}
>
  <img
    src="/logo/logo-white.svg"
    alt=""
    class="h-7 w-auto"
    loading="eager"
    decoding="async"
    aria-hidden="true"
  />
  <span>Khonsu Development</span>
</span>
