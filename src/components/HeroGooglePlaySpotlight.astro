---
import LaurelFrond from "./LaurelFrond.astro";

type Stat = { label: string; value: string };

export interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;

const isRatingStat = (s: Stat) =>
  /\b(rating|stars?)\b/i.test(s.label) || /★|⭐|star/i.test(s.value);

const displayValue = (s: Stat) =>
  isRatingStat(s) ? s.value.replace(/[★⭐]/g, "").trim() : s.value;

/** Heroicons solid star shape, 24×24 — works with a vertical midline clip for 4½ stars */
const STAR_PATH =
  "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.728a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.728a1 1 0 00-1.176 0l-3.976 2.728c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.728c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z";

const starIconClass = "size-[0.7rem] shrink-0 sm:size-[0.875rem]";
---

<section
  aria-label="Google Play highlights"
  class="relative mx-auto mt-8 max-w-4xl px-4 sm:mt-10 sm:px-8"
>
  <div
    class="flex flex-col items-stretch gap-10 sm:flex-row sm:justify-center sm:gap-6 lg:gap-14"
  >
    {
      stats.map((s, rowIndex) => (
        <div class="flex min-w-0 flex-1 items-center justify-center gap-1 sm:gap-2">
          <LaurelFrond class="h-[4.25rem] w-auto shrink-0 text-white/90 sm:h-[5.5rem]" />
          <div class="min-w-0 px-1 text-center sm:px-2">
            {isRatingStat(s) ? (
              <div
                class="mb-2 flex justify-center gap-px text-amber-300 sm:gap-[2px]"
                aria-hidden="true"
              >
                {Array.from({ length: 4 }).map(() => (
                  <svg
                    class:list={[starIconClass]}
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path fill="currentColor" d={STAR_PATH} />
                  </svg>
                ))}
                {/* Full muted star beneath, crisp left-half fill on top (true half-star geometry) */}
                <svg
                  class:list={[starIconClass]}
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <defs>
                    <clipPath
                      id={`hero-gp-half-${rowIndex}`}
                      clipPathUnits="userSpaceOnUse"
                    >
                      <rect width="12" height="24" />
                    </clipPath>
                  </defs>
                  <path fill="currentColor" opacity="0.28" d={STAR_PATH} />
                  <path
                    fill="currentColor"
                    clip-path={`url(#hero-gp-half-${rowIndex})`}
                    d={STAR_PATH}
                  />
                </svg>
              </div>
            ) : null}
            <p class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
              {displayValue(s)}
            </p>
            <p class="mt-2 text-xs leading-snug font-medium text-pretty text-zinc-300 sm:text-sm">
              {s.label}
            </p>
          </div>
          <LaurelFrond
            mirrored
            class="h-[4.25rem] w-auto shrink-0 text-white/90 sm:h-[5.5rem]"
          />
        </div>
      ))
    }
  </div>
</section>
